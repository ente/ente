APP_DISPLAY_NAME = Ente Self-Hosted
ASSETCATALOG_COMPILER_APPICON_NAME = IconGreen
CLANG_ENABLE_MODULES = YES
CODE_SIGN_ENTITLEMENTS = Runner/SelfHostedRunner.entitlements
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_STYLE = Automatic
CURRENT_PROJECT_VERSION = 11
CUSTOM_GROUP_ID = group.com.vanton1.ente.photos.selfhosted
DEVELOPMENT_TEAM = $(SELF_HOSTED_DEVELOPMENT_TEAM)
